class Solution(object):

    def countSubstrings(self, s):

        count = 0

        def expand(left, right):

            temp = 0

            while left >= 0 and right < len(s) and s[left] == s[right]:

                temp += 1

                left -= 1
                right += 1

            return temp

        for i in range(len(s)):

            # odd palindrome
            count += expand(i, i)

            # even palindrome
            count += expand(i, i + 1)

        return count
